// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Company {
  id           String    @id @default(cuid())
  name         String
  dotNumber    String?
  email        String?
  additionalEmails String?  // Comma-separated additional DER emails
  phone        String?
  address      String?
  city         String?
  state        String?
  zip          String?
  queryBalance         Int       @default(0)
  lastBulkQueryDate    DateTime?
  nextBulkQueryDueDate DateTime?
  
  // Clearinghouse Registration Tracking
  clearinghouseRegistered Boolean @default(false)
  ctpaDesignated          Boolean @default(false)
  registrationDate        DateTime?

  // Automated Email Scheduling Flags
  autoSendBuyQueriesDate   DateTime?
  autoSendUpdateRosterDate DateTime?
  autoSend10DaysBefore     Boolean   @default(false)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  drivers              Driver[]
  queries              Query[]
}

model Driver {
  id               String      @id @default(cuid())
  firstName        String
  lastName         String
  cdlNumber        String
  cdlState         String
  dob              DateTime?
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  consents         Consent[]
  queries          Query[]
  violations       Violation[]
  notes            DriverNote[]
  lastQueryDate    DateTime?
  nextQueryDueDate DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model DriverNote {
  id        String   @id @default(cuid())
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  content   String
  createdBy String
  createdAt DateTime @default(now())
}

model Consent {
  id          String   @id @default(cuid())
  driverId    String
  driver      Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  type        String   // "LIMITED" or "FULL"
  status      String   // "ACTIVE", "EXPIRED", "REVOKED", "REFUSED"
  validUntil  DateTime?
  documentUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Query {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  type        String   // "LIMITED" or "FULL"
  status      String   // "PENDING", "COMPLETED", "PROHIBITED", "ELIGIBLE"
  queryDate   DateTime @default(now())
  result      String?
  documentUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Violation {
  id            String         @id @default(cuid())
  driverId      String
  driver        Driver         @relation(fields: [driverId], references: [id], onDelete: Cascade)
  violationDate DateTime
  violationType String         // e.g., "POSITIVE_DRUG", "POSITIVE_ALCOHOL", "REFUSAL"
  reportedBy    String         // Who reported it
  status        String         // e.g., "PENDING_RTD", "RTD_ELIGIBLE", "CLEARED"
  notes         String?
  
  // SAP Information
  sapName       String?
  sapPhone      String?
  sapEmail      String?
  
  // RTD Milestone Dates
  removedFromDutyDate    DateTime?
  sapInitialEvalDate     DateTime?
  treatmentCompletedDate DateTime?
  sapFollowUpEvalDate    DateTime?
  rtdTestDate            DateTime?
  rtdTestResult          String?   // "NEGATIVE", "POSITIVE"
  clearedDate            DateTime?

  followUpTests FollowUpTest[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model FollowUpTest {
  id          String    @id @default(cuid())
  violationId String
  violation   Violation @relation(fields: [violationId], references: [id], onDelete: Cascade)
  dueDate     DateTime
  status      String    // e.g., "PENDING", "COMPLETED", "MISSED"
  result      String?   // e.g., "NEGATIVE", "POSITIVE"
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SystemSettings {
  id                String   @id @default("default")
  notificationEmail String?
  // Auto-reminder thresholds (days before due)
  consentExpiryWarningDays  Int @default(30)
  bulkQueryWarningDays      Int @default(30)
  // Low balance threshold
  lowBalanceThreshold       Int @default(5)
  // SMTP / Email config
  smtpHost          String?  // e.g. smtp.sendgrid.net
  smtpPort          Int?     // e.g. 587
  smtpUser          String?  // API key or username
  smtpPass          String?  // Password (stored encrypted)
  smtpFromEmail     String?  // e.g. noreply@clearinghousegroup.com
  smtpFromName      String?  // e.g. "ClearinghouseGroup"
  // Password policy
  passwordMinLength          Int     @default(8)
  passwordRequireUppercase   Boolean @default(true)
  passwordRequireNumber      Boolean @default(true)
  passwordRequireSpecial     Boolean @default(false)
  // Idle timeout
  idleTimeoutMinutes Int @default(15)
  updatedAt         DateTime @updatedAt
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String   // bcrypt hashed
  name        String
  role        String   @default("VIEWER") // "ADMIN" or "VIEWER"
  lastLoginAt DateTime?
  lastLoginIp String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String   // e.g., "LOGIN", "VIEW_DRIVER", "EXPORT_DATA", "CREATE_USER", "DELETE_USER"
  target    String?  // e.g., "driver:cm123", "company:cm456"
  details   String?  // Additional context
  ipAddress String?
  createdAt DateTime @default(now())
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean
  ipAddress String?
  createdAt DateTime @default(now())
}

model EmailTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique  // e.g. "prohibited_alert", "consent_request"
  name        String             // Display name
  subject     String             // Email subject line
  body        String             // HTML email body
  description String?            // When it's triggered
  updatedAt   DateTime @updatedAt
}
